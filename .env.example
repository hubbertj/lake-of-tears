# Lake of Tears — environment configuration
# Copy this file to .env and fill in your values before running docker compose.

# ── MinIO (S3-compatible object storage) ─────────────────────────────────────
# Root user: 5–20 alphanumeric characters
MINIO_ROOT_USER=lakeadmin
# Root password: 8–40 characters
MINIO_ROOT_PASSWORD=changeme_at_least_8_chars

# ── Lake UI ───────────────────────────────────────────────────────────────────
# These are read by the UI container to connect to MinIO and Gemini.
# When running via docker compose, MINIO_ENDPOINT should be the docker service name.
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=lakeadmin
MINIO_SECRET_KEY=changeme_at_least_8_chars
MINIO_BUCKET=datalake

# ── Jupyter ───────────────────────────────────────────────────────────────────
JUPYTER_TOKEN=change_me_to_a_strong_token

# ── Apache Superset ───────────────────────────────────────────────────────────
SUPERSET_ADMIN_PASSWORD=change_me
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SUPERSET_SECRET_KEY=change_me_to_a_long_random_string

# ── Apache Airflow ────────────────────────────────────────────────────────────
AIRFLOW_PASSWORD=change_me
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=change_me_to_a_long_random_string

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Data sources (optional — only needed for the built-in ingest pipelines) ───

# TrueNAS SCALE API
# TRUENAS_HOST=192.168.1.100
# TRUENAS_API_KEY=

# Jellyfin media server
# JELLYFIN_URL=http://192.168.1.100:8096
# JELLYFIN_API_KEY=

# Open-Meteo weather (no key needed; override location if desired)
# WEATHER_LAT=40.7934
# WEATHER_LON=-77.8600

# ── Volume mount path (Docker Compose) ───────────────────────────────────────
# The host directory used for Jupyter notebooks, Airflow DAGs, and pipeline scripts.
# Defaults to your home directory. Override if running as a different user.
DATALAKE_DATA_DIR=~
