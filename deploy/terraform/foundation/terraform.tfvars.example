truenas_host             = "10.0.0.160"
truenas_password         = "YOUR_TRUENAS_ROOT_PASSWORD"
zfs_pool                 = "WB-RAID-Z-18TB"
# snapshot_retention_days = 30   # days to keep daily ZFS snapshots (default 30)

# MinIO CE credentials — must match the values in terraform/services/terraform.tfvars
# Apply terraform/services first (so MinIO CE is running), then apply foundation
# to register the datalake bucket via Terraform state.
aistor_endpoint          = "10.0.0.60:9000"
aistor_access_key        = "YOUR_MINIO_ROOT_USER"
aistor_secret_key        = "YOUR_MINIO_ROOT_PASSWORD"
